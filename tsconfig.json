{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@view/*": ["src/view/*"], 
      "@store/*": ["src/store/*"], 
      "@utils/*": ["src/utils/*"], 
    }
  }
}